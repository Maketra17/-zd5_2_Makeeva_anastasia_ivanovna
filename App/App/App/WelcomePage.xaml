<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.WelcomePage"
             Title="Вход">
    <ContentPage.Content>
        <StackLayout Padding="20" Spacing="15" VerticalOptions="Center">
            <Label Text="Welcome" 
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1976D2"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Label Text="Username" 
                   FontSize="14" 
                   TextColor="#333" 
                   Margin="0,5,0,5"/>
            <Entry x:Name="UsernameEntry" 
                   Placeholder="Enter username"
                   BackgroundColor="#F5F5F5"
                   TextColor="#000"
                   HeightRequest="40"/>

            <Label Text="Password" 
                   FontSize="14" 
                   TextColor="#333" 
                   Margin="0,10,0,5"/>
            <Entry x:Name="PasswordEntry" 
                   Placeholder="Enter password"
                   IsPassword="True"
                   BackgroundColor="#F5F5F5"
                   TextColor="#000"
                   HeightRequest="40"/>

            <Button Text="Sign in" 
                    BackgroundColor="#1976D2"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="5"
                    HeightRequest="50"
                    Clicked="OnSignInClicked"
                    Margin="0,20,0,0"/>

            <StackLayout Orientation="Horizontal" 
                         Spacing="10" 
                         Margin="0,10,0,5">
                <CheckBox x:Name="RememberCheck" />
                <Label Text="Remember me" 
                       VerticalOptions="Center" 
                       FontSize="14" 
                       TextColor="#333"/>
            </StackLayout>

            <Label Text="I forgot!" 
                   TextColor="#1976D2"
                   HorizontalOptions="Center"
                   FontSize="14"
                   Margin="0,5,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnForgotTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <Label x:Name="ErrorLabel" 
                   Text="" 
                   TextColor="Red" 
                   IsVisible="False"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>