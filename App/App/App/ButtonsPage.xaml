<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.ButtonsPage"
             Title="Кнопки">
    <ContentPage.Content>
        <StackLayout Padding="20" Spacing="15" VerticalOptions="Center">
            <Label x:Name="WelcomeLabel" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="#1976D2" 
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"/>

            <Label x:Name="InfoLabel" 
                   FontSize="14" 
                   TextColor="#333" 
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Label Text="BUTTON" FontSize="16" FontAttributes="Bold" TextColor="#333" Margin="0,5,0,5"/>
            <Button Text="BUTTON" BackgroundColor="#1976D2" TextColor="White" FontSize="16" HeightRequest="50" CornerRadius="5"/>

            <Label Text="LARGE" FontSize="16" FontAttributes="Bold" TextColor="#333" Margin="0,10,0,5"/>
            <Button Text="BUTTON" BackgroundColor="#1976D2" TextColor="White" FontSize="20" HeightRequest="60" CornerRadius="10"/>

            <Label Text="NORMAL" FontSize="16" FontAttributes="Bold" TextColor="#333" Margin="0,10,0,5"/>
            <Button Text="BUTTON" BackgroundColor="#4CAF50" TextColor="White" FontSize="16" HeightRequest="50" CornerRadius="5"/>

            <Label Text="SMALL" FontSize="16" FontAttributes="Bold" TextColor="#333" Margin="0,10,0,5"/>
            <Button Text="BUTTON" BackgroundColor="#FF9800" TextColor="White" FontSize="12" HeightRequest="35" CornerRadius="3"/>

            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="Назад" 
                        BackgroundColor="#757575" 
                        TextColor="White" 
                        FontSize="16" 
                        HeightRequest="50" 
                        CornerRadius="5" 
                        Clicked="OnBackClicked"
                        HorizontalOptions="FillAndExpand"/>

                <Button Text="Далее →" 
                        BackgroundColor="#1976D2" 
                        TextColor="White" 
                        FontSize="16" 
                        HeightRequest="50" 
                        CornerRadius="5" 
                        Clicked="OnNextClicked"
                        HorizontalOptions="FillAndExpand"/>
            </StackLayout>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>